# =============================================
# Sales IQ - Environment Configuration
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# --- Application ---
APP_NAME=SalesIQ
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=salesiq
POSTGRES_PASSWORD=salesiq_dev_2024
POSTGRES_DB=salesiq
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=salesiq_redis_dev
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# --- MinIO (S3-compatible object storage) ---
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=salesiq_minio
MINIO_ROOT_PASSWORD=salesiq_minio_dev_2024
MINIO_BUCKET=salesiq-documents

# --- AI / LLM ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# --- SSO / Auth ---
# Azure AD OIDC
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=http://localhost:3000/api/auth/callback/azure-ad

# Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# JWT
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- ERP Connectors ---
# D365 Finance & Operations
D365_TENANT_ID=
D365_CLIENT_ID=
D365_CLIENT_SECRET=
D365_RESOURCE_URL=

# Salesforce
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_INSTANCE_URL=

# --- Email (Briefing Delivery) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=briefings@salesiq.ai
SMTP_TLS=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
